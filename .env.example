# Copie este arquivo para .env e preencha os valores.

# Credenciais da API Telegram (my.telegram.org)
API_ID=123456
API_HASH=coloque_seu_api_hash

# Telefone da conta (necessario apenas no primeiro login da sessao)
PHONE=+5511999999999

# Senha 2FA (se sua conta usa verificacao em duas etapas)
TWOFA_PASSWORD=

# Se true, nao pede confirmacao "APAGAR"
AUTO_CONFIRM=false
